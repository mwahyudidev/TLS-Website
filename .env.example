# Database — untuk cPanel gunakan file lokal (tidak perlu akun Turso)
TURSO_DATABASE_URL=file:./db/data/store.db
TURSO_AUTH_TOKEN=

# Untuk Vercel/Netlify/Turso cloud, ganti dengan:
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-token-here

# Session
NODE_ENV=production

# Seed (hanya dipakai saat npm run db:seed)
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=GantiPassword!2026
